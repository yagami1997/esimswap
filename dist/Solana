<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>404 Not Found</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/error.js" defer></script>
</head>
<body class="error-gate-body">
    <main class="error-gate">
        <section class="error-gate-panel">
            <div class="error-gate-brand">eSIM Gate</div>
            <p class="error-gate-kicker">ERROR 404</p>
            <h1 class="error-gate-code">404</h1>
            <h2>Not Found</h2>
            <p class="error-gate-copy">The requested resource could not be located. The address may be invalid, incomplete, or no longer available.</p>

            <section class="error-gate-redirect" aria-label="Redirect notice">
                <div class="error-gate-spinner" aria-hidden="true"></div>
                <h3>Redirecting to Cloudflare</h3>
                <p>Automatically redirecting in <strong id="redirectCountdown">5</strong> seconds.</p>
                <a id="cloudflareRedirect" class="btn btn-primary error-gate-button" href="https://www.cloudflare.com/" rel="nofollow">Go now</a>
                <noscript>
                    <p class="error-gate-noscript">JavaScript is disabled. Use the button to continue to Cloudflare.</p>
                </noscript>
            </section>

            <footer class="error-gate-footer">
                Public errors are intentionally brief. Powered by <strong>Cloudflare</strong>.
            </footer>
        </section>
    </main>
</body>
</html>
